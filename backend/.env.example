# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration
# For Docker MongoDB (recommended for development)
MONGO_URI=mongodb://eventuser:eventpassword@localhost:27017/eventbooking?authSource=eventbooking

# Alternative: Local MongoDB installation
# MONGO_URI=mongodb://localhost:27017/eventbooking

# Alternative: MongoDB Atlas (cloud)
# MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/eventbooking

# Frontend Configuration
FRONTEND_URL=http://localhost:3000

# File Upload Configuration (Optional)
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/